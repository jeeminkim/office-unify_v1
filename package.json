{
  "name": "jimin-ai-office",
  "version": "1.0.0",
  "private": true,
  "description": "Discord + Supabase multi-agent investment office bot",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "control-panel": "node dist/apps/control-panel/server.js",
    "control-panel:dev": "ts-node apps/control-panel/server.ts",
    "check:schema-contract": "ts-node scripts/check-schema-contract.ts",
    "check:phase1-structure": "node -r ./scripts/setDummySupabaseEnv.cjs -r ts-node/register scripts/phase1-structure-self-check.ts",
    "check:runtime-e2e": "ts-node scripts/runtime-e2e-check.ts",
    "check:decision-engine": "ts-node scripts/decision-engine-self-check.ts"
  },
  "dependencies": {
    "express": "^4.21.2",
    "@google/genai": "^1.16.0",
    "@supabase/supabase-js": "^2.56.0",
    "discord.js": "^14.22.1",
    "dotenv": "^17.3.1",
    "openai": "^6.5.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.18.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
